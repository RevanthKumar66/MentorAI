# ==========================================
# MentorAI OS Environment Template
# ==========================================

# ------------------------------------------
# FRONTEND CONFIG (apps/web)
# ------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ------------------------------------------
# BACKEND CONFIG (services/api)
# ------------------------------------------
PROJECT_NAME="MentorAI OS"
ENV=development # development, staging, production
DEBUG=true

# Database Settings
# Supports local postgres or Supabase DB. Must use asyncpg.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mentorai

# Supabase Platform Configurations
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT Settings
JWT_ALGORITHM=RS256

# Redis & Celery Settings
REDIS_URL=redis://localhost:6379/0

# LLM Configs
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
OLLAMA_BASE_URL=http://localhost:11434

# Google OAuth Credentials (for Gmail/Calendar sync and token refresh)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
